# PostgreSQL connection string (required)
# Local Docker (optional): run `pnpm run db:up` then use:
# DATABASE_URL=postgresql://relay:relay@localhost:5432/relay_leaderboard
#
# Supabase (recommended cloud): use your project connection string:
# DATABASE_URL=postgresql://postgres:<password>@db.<project-ref>.supabase.co:5432/postgres?sslmode=require
DATABASE_URL=postgresql://postgres:<password>@db.<project-ref>.supabase.co:5432/postgres?sslmode=require

# Relay API key (optional but recommended for rate limits)
# RELAY_API_KEY=

# API server port
PORT=3001

# Comma-separated list of allowed CORS origins.
#
# ⚠️  SECURITY WARNING: leaving this empty allows ALL origins, which exposes
# the API to CSRF and unauthorized cross-origin requests. In production you
# MUST explicitly list every trusted origin.
#
# Use environment-specific values:
#   Development: CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:5174
#   Production:  CORS_ALLOWED_ORIGINS=https://yoursite.github.io
#
# Only include localhost entries during local development; never in production.
# CORS_ALLOWED_ORIGINS=https://yoursite.github.io,http://localhost:5173
